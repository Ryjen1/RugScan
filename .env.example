# Optional — better RPC for tokens Jupiter doesn't know about
# (Jupiter Tokens V2 is the primary source; this is only used as a fallback
# for very-new mints that haven't been indexed yet).
# Free tier: https://www.helius.dev
HELIUS_API_KEY=

# Optional — explicit RPC URL override (takes precedence over HELIUS_API_KEY).
SOLANA_RPC_URL=

# Optional — enables LLM-powered explanations & chat.
# Without this, Shrewd Guard streams a deterministic structured explanation built
# from the analysis. The demo still works perfectly without it.
#
# Get a free Groq key (high rate limits, free Llama 3.3 70B):
# https://console.groq.com
GROQ_API_KEY=

# Or use OpenAI (gpt-4o-mini is selected if GROQ_API_KEY is not set)
OPENAI_API_KEY=
